# ─────────────────────────────────────────────
# VORTEX v3 — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Server port (Nginx will proxy to this)
PORT=3001

# Set to true when deployed publicly on a VPS
# Leave blank or false for local/LAN use
VORTEX_PUBLIC=true

# Secret token — share this with your friends
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VORTEX_TOKEN=replace_this_with_a_strong_secret

# Log level: error | warn | info | http | debug
LOG_LEVEL=info

# Trust 1 proxy layer (Nginx) for correct client IPs
TRUST_PROXY=1
